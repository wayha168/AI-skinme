# Backend (Spring Boot at backend.skinme.store): chat logs and feedback are POSTed here
# SPRING_BACKEND_URL=https://backend.skinme.store

# Optional: same MySQL as Spring for live product recommendations in chat (use_database=true)
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_USER=your_user
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=skinme_db
# MYSQL_PRODUCTS_TABLE=product

# Optional: OpenAI for LLM replies
# OPENAI_API_KEY=sk-...
