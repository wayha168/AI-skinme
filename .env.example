# Public URL of this chatbot API (for docs/links). Used when deployed at chatbot.skinme.store
# CHATBOT_URL=https://chatbot.skinme.store

# Backend (Spring Boot at backend.skinme.store): chat logs and feedback are POSTed here
# SPRING_BACKEND_URL=https://backend.skinme.store

# Same MySQL as your backend (skinme_db) — chat_ai, chat_sessions, and product lookups use this DB
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_USER=your_user
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=skinme_db
# MYSQL_PRODUCTS_TABLE=product

# Optional: Google Gemini for LLM chat replies (GEMINI_API_KEY or GOOGLE_API_KEY)
# GEMINI_API_KEY=your-google-ai-studio-key
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Set to false to force retrieval-only replies even if a key is present
# GOOGLE_API_ENABLED=true

# Chat: set use_database=true (API/Streamlit) to merge MySQL products with scraped skinme_products.csv
